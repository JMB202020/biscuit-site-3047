      <li><a href="/3047/reviews-html" class="hover:text-[var(--color-brand-accent)]">Reviews</a></li>
      <li><a href="/3047/enquiry-form-html" class="hover:text-[var(--color-brand-accent)]">Enquiry Form</a></li>
      <li><a href="/3047/booking-forms-html" class="hover:text-[var(--color-brand-accent)]">Booking Forms</a></li>
      <li><a href="/3047/gallery-html" class="text-[var(--color-brand-accent)] font-700">Gallery</a></li>
      <li><a href="/3047/compartments-html" class="hover:text-[var(--color-brand-accent)]">Compartments</a></li>
    </ul>
  </div>
</nav>

<!-- Page hero -->
<section class="relative h-52 flex items-center overflow-hidden">
