  <div class="relative z-10 max-w-4xl mx-auto px-6">
    <span class="text-[var(--color-brand-accent)] text-sm font-700">📍 Ramsgate, Kent</span>
    <h1 class="text-white font-800 mt-2">Gallery</h1>
  </div>
</section>

